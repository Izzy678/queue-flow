{
  "name": "queueflow",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev -w @queueflow/web\" \"npm run start:dev -w @queueflow/api\"",
    "dev:web": "npm run dev -w @queueflow/web",
    "dev:api": "npm run start:dev -w @queueflow/api",
    "build": "npm run build -w @queueflow/api && npm run build -w @queueflow/web",
    "build:web": "npm run build -w @queueflow/web",
    "build:api": "npm run build -w @queueflow/api",
    "lint": "npm run lint -w @queueflow/web",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
